# Railway injects DATABASE_URL automatically once you add the PostgreSQL
# plugin to this service — you don't need to set it by hand in production.
# For running locally against your own Postgres, set it here:
DATABASE_URL=postgres://user:password@localhost:5432/bos_dashboard

# Required. Any long random string — used to sign login tokens.
# Generate one with: openssl rand -base64 32
JWT_SECRET=replace-this-with-a-long-random-string

# Used ONLY the very first time the app starts (when the users table is
# empty) to create the first admin login. Change this password immediately
# after first login via the Admin tab, then these two variables can be
# removed from Railway.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

NODE_ENV=production
